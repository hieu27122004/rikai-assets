<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_rikai_asset_list" model="ir.ui.view">
        <field name="name">rikai.asset.list</field>
        <field name="model">rikai.asset</field>
        <field name="arch" type="xml">
            <list string="Assets" default_order="name asc">
                <field name="name"/>
                <field name="asset_code"/>
                <field name="category_id"/>
                <field name="condition"/>
                <field name="state"/>
                <field name="employee_id"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <record id="view_rikai_asset_form" model="ir.ui.view">
        <field name="name">rikai.asset.form</field>
        <field name="model">rikai.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">

                <header>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="available,in_use,return_requested,maintenance,retired"/>
                </header>

                <sheet>

                    <group col="2">

                        <group>
                            <field name="name"/>
                            <field name="asset_code"/>
                            <field name="subcompany"/>
                            <field name="category_id"/>
                            <field name="condition"/>
                            <field name="state"/>
                            <field name="inventory_status" groups="rikai_assets.group_rikai_asset_admin"/>
                        </group>

                    </group>

                    <group col="2">
                        <field name="description" colspan="2"/>
                        <field name="qr_code"
                               widget="image"
                               readonly="1"/>
                    </group>

                    
                    <group>
                        <field name="employee_id"/>
                        <field name="leader_id"/>
                        <field name="department_id"/>
                    </group>

                    <group>
                        <field name="front_image" widget="image" options="{'size':[250,250]}"/>
                        <field name="back_image" widget="image" options="{'size':[250,250]}"/>
                        <field name="extra_image" widget="image" options="{'size':[250,250]}"/>
                    </group>

                    <notebook>

                        <page string="Usage History">
                            <field name="usage_ids">

                                <list>
                                    <field name="employee_id"/>
                                    <field name="leader_id"/>
                                    <field name="department_id"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="state"/>
                                </list>

                                <form string="Usage History">
                                    <sheet>
                                        <group col="2">
                                            <group>
                                                <field name="employee_id"/>
                                                <field name="leader_id"/>
                                                <field name="department_id"/>
                                            </group>
                                            <group>
                                                <field name="start_date"/>
                                                <field name="end_date"/>
                                                <field name="state"/>
                                            </group>
                                        </group>

                                        <group>
                                            <field name="photo_in"
                                                   widget="image"
                                                   options="{'size':[250,250]}"/>
                                            <field name="photo_out"
                                                   widget="image"
                                                   options="{'size':[250,250]}"/>
                                        </group>
                                    </sheet>
                                </form>

                            </field>
                        </page>

                    </notebook>

                </sheet>

                <chatter/>

            </form>
        </field>
    </record>

    <record id="action_rikai_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">rikai.asset</field>
        <field name="view_mode">list,form</field>
        <field name="context">
            {
                'group_by': ['subcompany', 'category_id']
            }
        </field>
    </record>

</odoo>