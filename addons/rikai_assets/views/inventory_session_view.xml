<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_inventory_session_form" model="ir.ui.view">
        <field name="name">rikai.inventory.session.form</field>
        <field name="model">rikai.inventory.session</field>
        <field name="arch" type="xml">

            <form string="Inventory Session">

                <header>
                    <button name="action_start"
                            string="Start Inventory"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_end"
                            string="End Inventory"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'running'"/>

                    <field name="state" widget="statusbar"/>
                </header>

                <sheet>
                    <group>
                        <field name="name" readonly="state != 'draft'"/>
                        <field name="start_date" readonly="1"/>
                        <field name="end_date" readonly="1"/>
                    </group>

                    <group invisible="state != 'running'">
                        <button name="action_open_scanner"
                                string="Scan by Camera"
                                type="object"
                                class="btn-primary"/>
                    </group>

                    <notebook>
                        <page string="Checked Assets">
                            <field name="checked_asset_ids" readonly="1"/>
                        </page>

                        <page string="Missing Assets">
                            <field name="missing_asset_ids" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>

            </form>

        </field>
    </record>

    <!-- Inventory Assets: list view riêng cho kiểm kê, có cột inventory_status -->
    <record id="view_rikai_asset_inventory_list" model="ir.ui.view">
        <field name="name">rikai.asset.inventory.list</field>
        <field name="model">rikai.asset</field>
        <field name="arch" type="xml">
            <list string="Inventory Assets" default_order="inventory_status asc, name asc">
                <field name="name"/>
                <field name="asset_code"/>
                <field name="category_id"/>
                <field name="state"/>
                <field name="inventory_status"
                       decoration-success="inventory_status == 'available'"
                       decoration-danger="inventory_status == 'not_available'"/>
                <field name="employee_id"/>
                <field name="department_id"/>
            </list>
        </field>
    </record>

    <record id="action_inventory_assets" model="ir.actions.act_window">
        <field name="name">Inventory Assets</field>
        <field name="res_model">rikai.asset</field>
        <field name="view_mode">list,form</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_rikai_asset_inventory_list')})]"/>
        <field name="domain">[('state', '!=', 'retired')]</field>
    </record>

</odoo>